library(xts)
#library(readxl)
#library(astsa)
library(ggfortify)
library(forecast)
library(fpp2)
#library(seasonal)
help(marathon) # Winning times (in minutes) for the Boston Marathon Men's Open Division. Annual frequency 1897-2016.
autoplot(marathon)
# a) Use ses() to forecast the next 10 years of winning times for Boston marathon. Call it fc.
fc <- ses(marathon, h = 10)
# b) Use summary() to see the model parameters and other information for the object "fc".
summary(fc)
# c) Use autoplot() to plot the forecasts of "fc".
autoplot(fc)
# d) Add the fitted values to the plot using fitted() and autolayer().
autoplot(fc) + autolayer(fitted(fc))
#-----------------------------------------------------------
#!            Exercice 2: Forecast accuracy of SES         !
#-----------------------------------------------------------
# a) Using the function subset(), create a training set for marathon comprising all but
#    the last 20 years of the data which you will reserve for testing. Call this "train".
train <- subset(marathon, end = length(marathon) - 20)
#-----------------------------------------------------------
#!            Exercice 2: Forecast accuracy of SES         !
#-----------------------------------------------------------
# a) Using the function subset(), create a training set for marathon comprising all but
#    the last 20 years of the data which you will reserve for testing. Call this "train".
train <- subset(marathon, end = length(marathon) - 20)
# b) Compute the SES and naive forecasts of this training set and save them to fcses and fcnaive, respectively.
fcses <- ses(train, h = 20)
fcnaive <- naive(train, h = 20)
# c) Use autoplot() to plot the forecasts
autoplot(fcses)
autoplot(fcnaive)
# d) Calculate forecast accuracy measures of the two sets of forecasts using the accuracy() function in your console.
accuracy(fcses, marathon)
# a) Produce 10 year forecasts of oil using holt(). Call it fcholt.
fcholt <- ses(oil, h=10)
# b) Look at fitted model using summary().
summary(fcholt)
# c) Plot the forecasts
autoplot(fcholt)
# d) Check that the residuals look like white noise using function checkresiduals()
checkresiduals(fcholt)
# e) Normal vs damped trend
# e1) Produce 10 year forecasts of oil using holt(). Remove prediction interval using the
#     option "PI = FALSE". Call it fcholt1.
fcholt1 <- holt(fcholt, h = 10, PI = FALSE)
# e) Normal vs damped trend
# e1) Produce 10 year forecasts of oil using holt(). Remove prediction interval using the
#     option "PI = FALSE". Call it fcholt1.
fcholt1 <- holt(oil, h = 10, PI = FALSE)
# e2) Produce the same prediction with damped trend using the option "damped = TRUE". Call it fcholt2.
fcholt2 <- holt(oil, h = 10, PI = TRUE)
# e3) Plot fcholt1 and fcholt2 together to see the impact of damped trend.
autoplot(oil) + xlab("Year") + ylab("millions of tonnes") +
autolayer(fcholt1, series="Linear trend") + autolayer(fcholt2, series="Damped trend")
# a) Adjsut the sample of the "austourists" to start from 2005 using the function window(). Call it "aust".
aust <- window(austourists, start = 2005)
autoplot(aust)
# b) Produce forecasts of "aust" using hw() with additive seasonality and save this to "fca".
fca <- hw(aust, seasonal = "additive")
# c) Do the residuals look like white noise? Check them using the appropriate function.
checkresiduals(fca)
# d) Plot forecasts
autoplot(fca)
# a) Produce forecasts of "a10" for the next 3 years using hw() with multiplicative seasonality and save this to fc.
fc <- hw(a10, seasonal = "multiplicative", h = 36)
# b) Do the residuals look like white noise? Check them using the appropriate function.
checkresiduals(fc)
# c) Plot forecasts
autoplot(fc)
# a) Using subset(), set up a training set where the last 4 weeks of the available data in hyndsight have been omitted.
train <- subset(hyndsight, end = length(hyndsight) - 28)
# b) Produce forecasts for these last 4 weeks using hw() and additive seasonality applied to the training data. Assign this to fchw.
fchw <- hw(train, seasonal = "additive", h = 28)
# c) Produce seasonal naive forecasts using snaive() for the same period and assign this to fcsn.
fcsn <- snaive(train, h = 28)
# d) Plot the two forecasts, hw and snaive
autoplot(fchw)
autoplot(snaive)
autoplot(snaive)
autoplot(fcsn)
# d) Plot the two forecasts, hw and snaive
autoplot(fchw)
# e) Which is the better of the two forecasts? Use the accuracy() function to determine this.
accuracy(a10, hyndsight)
# e) Which is the better of the two forecasts? Use the accuracy() function to determine this.
accuracy(fc, hyndsight)
# e) Which is the better of the two forecasts? Use the accuracy() function to determine this.
accuracy(fchw, hyndsight)
accuracy(fcsn, hyndsight)
