pannes$age_group <- NULL
modele.agemarque <- glm(etat ~ ., data = pannes, family = "binomial")
summary(modele.agemarque)
modele.interactions <- glm(etat ~ age + age2 + marque + age:marque + age2:marque, data = pannes, family = "binomial")
summary(modele.interactions)
# on utilise stepAIC pour faire une sélection de modèle automatique
library(MASS)
modele.step <- stepAIC(modele.interactions, direction = "both")
summary(modele.step)
# on utilise stepAIC pour faire une sélection de modèle automatique
library(MASS)
# on utilise stepAIC pour faire une sélection de modèle automatique
library(MASS)
modele.step <- stepAIC(modele.interactions, direction = "both")
summary(modele.step)
# on utilise stepAIC pour faire une sélection de modèle automatique
library(MASS)
modele.step <- stepAIC(modele.interactions, direction = "both")
summary(modele.step)
# version forward
modele.forward <- stepAIC(modele.age2, scope = list(lower = modele.age2, upper = modele.interactions), direction = "forward")
summary(modele.forward)
# version forward
modele.forward <- stepAIC(modele.age, scope = list(lower = modele.age, upper = modele.interactions), direction = "forward")
# on utilise stepAIC pour faire une sélection de modèle automatique
