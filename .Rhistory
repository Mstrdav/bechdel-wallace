DENS_INF +
DENS_KIN, data=data_clean)
bptest(reg_clean2)
library(strucchange)
mod_complet <- lm(log(DENS_MED_LIB) ~ DENSITE + PART_75 + TAUX_ACTIV +
PART_IMPOT + PART_TRANS_COMM + PART_PHARMA +
DENS_INF + DENS_KIN, data = data_clean)
# 2. Modèle avec interaction totale sur la variable UNIV
# Le "*" entre UNIV et la parenthèse applique l'interaction à TOUTES les variables
mod_interaction <- lm(log(DENS_MED_LIB) ~ UNIV * (DENSITE + PART_75 + TAUX_ACTIV +
PART_IMPOT + PART_TRANS_COMM + PART_PHARMA +
DENS_INF + DENS_KIN), data = data_clean)
# 3. Le Test de Chow (via un test d'ANOVA)
anova(mod_complet, mod_interaction)
